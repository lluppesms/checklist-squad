{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "appName": { "value": "#{APP_NAME}#" },
    "environmentCode": { "value": "#{ENVCODE}#" },
    "location": { "value": "#{RESOURCE_GROUP_LOCATION}#" },
    "instanceNumber": { "value": "#{INSTANCE_NUMBER}#" },
    "websiteOnly": { "value": false },
    "servicePlanName": { "value": "#{EXISTING_SERVICEPLAN_NAME}#" },
    "servicePlanResourceGroupName": { "value": "#{EXISTING_SERVICEPLAN_RESOURCE_GROUP_NAME}#" },
    "webAppKind": { "value": "linux" },
    "webSiteSku": { "value": "#{WEBSITE_SKU}#" },
    "sqlDatabaseName": { "value": "#{SQL_DATABASE_NAME}#" },
    "existingSqlServerName": { "value": "#{EXISTING_SQLSERVER_NAME}#" },
    "existingSqlServerResourceGroupName": { "value": "#{EXISTING_SQLSERVER_RESOURCE_GROUP_NAME}#" },
    "sqlAdminLoginUserId": { "value": "#{SQLADMIN_LOGIN_USERID}#" },
    "sqlAdminLoginUserSid": { "value": "#{SQLADMIN_LOGIN_USERSID}#" },
    "sqlAdminLoginTenantId": { "value": "#{SQLADMIN_LOGIN_TENANTID}#" },
    "adminUserId": { "value": "#{KEYVAULT_OWNER_USERID}#" },
    "azureAdTenantId": { "value": "#{AZUREAD_APP_TENANT_ID}#" },
    "azureAdClientId": { "value": "#{AZUREAD_APP_CLIENT_ID}#" },
    "azureAdDomain": { "value": "#{AZUREAD_APP_DOMAIN}#" }
  }
}
