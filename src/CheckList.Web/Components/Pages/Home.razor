@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@inject IUserIdentity UserIdentity

<PageTitle>RigRoll</PageTitle>

<div class="home-container">
    <div class="hero-section">
        <div class="hero-image-wrapper">
            <img src="images/RV-Checklist.jpg" alt="Cheerful cartoon RV at a lakeside campground" class="hero-image" />
        </div>
        <h1 class="hero-title">
            Stop Shouting. Start RigRolling.
        </h1>
        <p class="hero-subheadline">
            Because "I thought you locked the storage bays" is the start of a very bad day.
        </p>
        <p class="hero-description">
            RigRoll is the collaborative, real-time checklist app that keeps your crew on the
            same page (and in a good mood). Whether you're leveling the jacks or stowing the
            shore power, everyone sees the progress live on their phone. No more guessing,
            no more forgetting the antenna, and absolutely no more yelling across the campsite.
        </p>
    </div>

    <AuthorizeView>
        <Authorized>
            <div class="welcome-card">
                <p class="welcome-text">
                    Welcome back, <strong>@UserIdentity.NickName</strong>! Ready to roll? 🚐
                </p>
            </div>

            <div class="quick-links">
                <a href="templates" class="quick-link-card">
                    <i class="bi bi-card-checklist"></i>
                    <div>
                        <h5>The Blueprints</h5>
                        <p>Choose your mission. Load a pro setup/teardown blueprint or build your own custom checklist.</p>
                    </div>
                </a>
                <a href="checklists" class="quick-link-card">
                    <i class="bi bi-clipboard-check"></i>
                    <div>
                        <h5>The Active Mission</h5>
                        <p>Jump back into your live lists. See what the crew has finished and what's left before it's time to relax.</p>
                    </div>
                </a>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="welcome-card">
                <p class="welcome-text">Sign in to access your checklists and collaborate with your crew! ⛺</p>
                <a href="/account/login" class="btn btn-primary mt-2">
                    <i class="bi bi-box-arrow-in-right"></i> Sign in with Microsoft
                </a>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>
