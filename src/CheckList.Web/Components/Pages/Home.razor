@page "/"

<PageTitle>Shared Checklist</PageTitle>

<div class="home-container">
    <div class="hero-section">
        <h1 class="hero-title">
            <i class="bi bi-clipboard-check"></i> Shared Checklist
        </h1>
        <p class="hero-description">
            Collaborative checklist for RV campground setup and teardown.
            Work together in real-time to make sure nothing gets missed.
        </p>
    </div>

    @if (UserIdentity.HasNickName)
    {
        <div class="welcome-card">
            <p class="welcome-text">
                Welcome back, <strong>@UserIdentity.NickName</strong>!
            </p>
        </div>

        <div class="quick-links">
            <a href="templates" class="quick-link-card">
                <i class="bi bi-card-checklist"></i>
                <div>
                    <h5>Templates</h5>
                    <p>Browse checklist templates and activate one</p>
                </div>
            </a>
            <a href="checklists" class="quick-link-card">
                <i class="bi bi-clipboard-check"></i>
                <div>
                    <h5>My Checklists</h5>
                    <p>View and work on active checklists</p>
                </div>
            </a>
        </div>
    }
    else
    {
        <div class="welcome-card">
            <p class="welcome-text">Enter your name above to get started!</p>
        </div>
    }
</div>

@code {
    [Inject] private IUserIdentity UserIdentity { get; set; } = default!;
}
