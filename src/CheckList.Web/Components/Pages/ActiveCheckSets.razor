@page "/checklists"

<PageTitle>My Checklists</PageTitle>

<h2 class="page-title">
    <i class="bi bi-clipboard-check"></i> My Checklists
</h2>

@if (loading)
{
    <LoadingSpinner Message="Loading checklists..." />
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @errorMessage
    </div>
}
else if (checkSets.Count == 0)
{
    <div class="empty-state">
        <i class="bi bi-signpost-split"></i>
        <p>No active checklists yet — time to hit the road! Head to <a href="templates">Templates</a> to start one. 🚐</p>
    </div>
}
else
{
    <div class="checklist-grid">
        @foreach (var cs in checkSets)
        {
            var isToday = cs.CreateDateTime.Date == DateTime.Today;
            <div class="checklist-card @(isToday ? "checklist-today" : "")">
                @if (isToday)
                {
                    <span class="today-badge"><i class="bi bi-calendar-check"></i> Today</span>
                }
                <a href="checklists/@cs.SetId" class="card-link">
                    <div class="card-body">
                        <h5 class="card-title">@cs.SetName</h5>
                        @if (!string.IsNullOrEmpty(cs.SetDscr))
                        {
                            <p class="card-description">@cs.SetDscr</p>
                        }
                        <div class="card-meta">
                            <span><i class="bi bi-person"></i> @cs.OwnerName</span>
                        </div>
                    </div>
                </a>
                <div class="card-footer">
                    <button class="btn btn-outline-danger btn-sm"
                            @onclick="() => PromptDelete(cs.SetId, cs.SetName)">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </div>
            </div>
        }
    </div>
}

<ConfirmDialog IsVisible="@showDeleteConfirm"
               Title="Delete Checklist"
               Message="@($"Are you sure you want to delete \"{deleteSetName}\"?")"
               ConfirmText="Delete"
               OnConfirm="ConfirmDelete"
               OnCancel="CancelDelete" />

@code {
    [Inject] private ICheckListApiClient ApiClient { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private List<CheckSetSummaryDto> checkSets = [];
    private bool loading = true;
    private string? errorMessage;
    private bool showDeleteConfirm;
    private int? deleteSetId;
    private string? deleteSetName;

    protected override async Task OnInitializedAsync()
    {
        await LoadCheckSets();
    }

    private async Task LoadCheckSets()
    {
        try
        {
            loading = true;
            checkSets = await ApiClient.GetActiveCheckSetsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load checklists: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void PromptDelete(int setId, string setName)
    {
        deleteSetId = setId;
        deleteSetName = setName;
        showDeleteConfirm = true;
    }

    private async Task ConfirmDelete()
    {
        if (deleteSetId is not null)
        {
            try
            {
                await ApiClient.DeleteCheckSetAsync(deleteSetId.Value);
                checkSets.RemoveAll(c => c.SetId == deleteSetId.Value);
            }
            catch (Exception ex)
            {
                errorMessage = $"Failed to delete checklist: {ex.Message}";
            }
        }
        showDeleteConfirm = false;
        deleteSetId = null;
        deleteSetName = null;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        deleteSetId = null;
        deleteSetName = null;
    }
}
