@page "/templates"
@attribute [Authorize]
@using Microsoft.JSInterop
@using System.Text.Json
@inject IJSRuntime JSRuntime

<PageTitle>Blueprints — RigRoll</PageTitle>

<h2 class="page-title">
    <i class="bi bi-card-checklist"></i> Blueprints
</h2>

<div class="template-actions mb-3">
    <button class="btn btn-primary" @onclick="CreateNewTemplate">
        <i class="bi bi-plus-lg"></i> Create New Blueprint
    </button>
</div>

@if (loading)
{
    <LoadingSpinner Message="Loading blueprints..." />
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @errorMessage
    </div>
}
else if (templates.Count == 0)
{
    <div class="empty-state">
        <i class="bi bi-compass"></i>
        <p>No blueprints yet — let's build your first adventure checklist! 🌲</p>
        <button class="btn btn-primary mt-2" @onclick="CreateNewTemplate">
            <i class="bi bi-plus-lg"></i> Create Your First Blueprint
        </button>
    </div>
}
else
{
    <div class="template-grid">
        @foreach (var template in templates)
        {
            <div class="template-card">
                <div class="card-body">
                    <h5 class="card-title">@template.SetName</h5>
                    <p class="card-description">@template.SetDscr</p>
                    <div class="card-meta">
                        <span><i class="bi bi-person"></i> @template.OwnerName</span>
                    </div>
                </div>
                <div class="card-footer">
                    <div class="btn-group w-100 mb-2">
                        <button class="btn btn-sm btn-outline-primary"
                                @onclick="() => EditTemplate(template.SetId)">
                            <i class="bi bi-pencil"></i> Edit
                        </button>
                        <button class="btn btn-sm btn-outline-secondary"
                                @onclick="() => ExportTemplate(template.SetId)">
                            <i class="bi bi-download"></i> Export
                        </button>
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => ShowDeleteConfirm(template.SetId, template.SetName)">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    </div>
                    <button class="btn btn-primary btn-sm w-100"
                            @onclick="() => ActivateTemplate(template.SetId)"
                            disabled="@activating">
                        @if (activatingId == template.SetId)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        <i class="bi bi-play-fill"></i> Activate
                    </button>
                </div>
            </div>
        }
    </div>
}

<ConfirmDialog IsVisible="@showDeleteDialog"
               Title="Delete Blueprint"
               Message="@deleteMessage"
               ConfirmText="Delete"
               OnConfirm="ConfirmDelete"
               OnCancel="CancelDelete" />

<ListSelectionDialog IsVisible="@showListSelectionDialog"
                     TemplateName="@selectedTemplateName"
                     Lists="@selectedTemplateLists"
                     OnConfirm="ConfirmActivateSelectedLists"
                     OnCancel="CancelListSelection" />

@code {
    [Inject] private ICheckListApiClient ApiClient { get; set; } = default!;
    [Inject] private IUserIdentity UserIdentity { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private List<TemplateSetSummaryDto> templates = [];
    private bool loading = true;
    private bool activating;
    private int? activatingId;
    private string? errorMessage;
    private bool showDeleteDialog;
    private int? deleteTargetId;
    private string deleteMessage = "";
    
    // List selection dialog state
    private bool showListSelectionDialog;
    private int? selectedTemplateId;
    private string selectedTemplateName = "";
    private List<TemplateListDto> selectedTemplateLists = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            templates = await ApiClient.GetTemplatesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load blueprints: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void CreateNewTemplate()
    {
        Navigation.NavigateTo("/templates/edit");
    }

    private void EditTemplate(int setId)
    {
        Navigation.NavigateTo($"/templates/edit/{setId}");
    }

    private async Task ExportTemplate(int setId)
    {
        try
        {
            var exportData = await ApiClient.ExportTemplateAsync(setId);
            var json = JsonSerializer.Serialize(exportData, new JsonSerializerOptions { WriteIndented = true });
            var fileName = $"Blueprint_{exportData.SetName.Replace(" ", "_")}_{DateTime.Now:yyyyMMdd_HHmmss}.json";
            await DownloadFile(fileName, json);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to export blueprint: {ex.Message}";
        }
    }

    private void ShowDeleteConfirm(int setId, string setName)
    {
        deleteTargetId = setId;
        deleteMessage = $"Are you sure you want to delete '{setName}'? This action cannot be undone.";
        showDeleteDialog = true;
    }

    private async Task ConfirmDelete()
    {
        showDeleteDialog = false;
        if (deleteTargetId.HasValue)
        {
            try
            {
                await ApiClient.DeleteTemplateSetAsync(deleteTargetId.Value);
                templates = await ApiClient.GetTemplatesAsync();
                deleteTargetId = null;
            }
            catch (Exception ex)
            {
                errorMessage = $"Failed to delete blueprint: {ex.Message}";
            }
        }
    }

    private void CancelDelete()
    {
        showDeleteDialog = false;
        deleteTargetId = null;
    }

    private async Task ActivateTemplate(int templateSetId)
    {
        if (!UserIdentity.HasNickName) return;

        try
        {
            activating = true;
            activatingId = templateSetId;
            
            // Fetch full template details to show list selection
            var template = await ApiClient.GetTemplateAsync(templateSetId);
            if (template is not null && template.Lists.Count > 0)
            {
                selectedTemplateId = templateSetId;
                selectedTemplateName = template.SetName;
                selectedTemplateLists = template.Lists;
                showListSelectionDialog = true;
            }
            else if (template is not null)
            {
                // No lists in template, activate anyway (edge case)
                var checkSet = await ApiClient.ActivateCheckSetAsync(templateSetId, UserIdentity.NickName!, ownerId: UserIdentity.UserId);
                if (checkSet is not null)
                {
                    Navigation.NavigateTo($"/checklists/{checkSet.SetId}");
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load blueprint details: {ex.Message}";
        }
        finally
        {
            activating = false;
            activatingId = null;
        }
    }

    private async Task ConfirmActivateSelectedLists((string Name, List<int> ListIds) confirmation)
    {
        showListSelectionDialog = false;
        if (!selectedTemplateId.HasValue || !UserIdentity.HasNickName) return;

        try
        {
            activating = true;
            activatingId = selectedTemplateId.Value;
            
            var checkSet = await ApiClient.ActivateCheckSetAsync(
                selectedTemplateId.Value, 
                UserIdentity.NickName!, 
                confirmation.ListIds,
                confirmation.Name,
                UserIdentity.UserId);
            
            if (checkSet is not null)
            {
                Navigation.NavigateTo($"/checklists/{checkSet.SetId}");
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to activate blueprint: {ex.Message}";
        }
        finally
        {
            activating = false;
            activatingId = null;
            selectedTemplateId = null;
            selectedTemplateName = "";
            selectedTemplateLists = [];
        }
    }

    private void CancelListSelection()
    {
        showListSelectionDialog = false;
        activating = false;
        activatingId = null;
        selectedTemplateId = null;
        selectedTemplateName = "";
        selectedTemplateLists = [];
    }

    private async Task DownloadFile(string fileName, string content)
    {
        var bytes = System.Text.Encoding.UTF8.GetBytes(content);
        var base64 = Convert.ToBase64String(bytes);
        await JSRuntime.InvokeVoidAsync("downloadFileFromBase64", fileName, base64);
    }
}
