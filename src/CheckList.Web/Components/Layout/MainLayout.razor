@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<div class="app-layout">
    <!-- Top Navbar -->
    <nav class="top-navbar">
        <div class="container-fluid d-flex align-items-center">
            <button class="navbar-toggler-btn d-md-none" @onclick="ToggleMenu" aria-label="Toggle navigation">
                <i class="bi bi-list"></i>
            </button>
            <a class="app-brand" href="">
                <i class="bi bi-clipboard-check me-2"></i>RigRoll
            </a>
            <div class="ms-auto d-flex align-items-center gap-2">
                <AuthorizeView>
                    <Authorized>
                        @if (UserIdentity.HasNickName)
                        {
                            <span class="user-badge d-none d-sm-inline">
                                <i class="bi bi-person-fill"></i> @UserIdentity.NickName
                            </span>
                        }
                        <form method="post" action="/account/logout" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-box-arrow-right"></i> <span class="d-none d-sm-inline">Sign out</span>
                            </button>
                        </form>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/account/login" class="btn btn-sm btn-primary">
                            <i class="bi bi-box-arrow-in-right"></i> <span class="d-none d-sm-inline">Sign in</span>
                        </a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </nav>

    <div class="app-body">
        <!-- Desktop sidebar -->
        <aside class="sidebar d-none d-md-flex">
            <NavMenu />
        </aside>

        <!-- Mobile sidebar overlay -->
        @if (menuOpen)
        {
            <div class="sidebar-overlay d-md-none" @onclick="ToggleMenu">
                <aside class="sidebar-mobile" @onclick:stopPropagation="true">
                    <NavMenu OnNavigated="ToggleMenu" />
                </aside>
            </div>
        }

        <!-- Main content -->
        <main class="main-content">
            <article class="content-area">
                @Body
            </article>
        </main>
    </div>

    <!-- Mobile bottom nav -->
    <nav class="bottom-nav d-md-none">
        <NavLink class="bottom-nav-item" href="" Match="NavLinkMatch.All">
            <i class="bi bi-house"></i>
            <span>Home</span>
        </NavLink>
        <AuthorizeView>
            <Authorized>
                <NavLink class="bottom-nav-item" href="templates">
                    <i class="bi bi-card-checklist"></i>
                    <span>Blueprints</span>
                </NavLink>
                <NavLink class="bottom-nav-item" href="checklists">
                    <i class="bi bi-clipboard-check"></i>
                    <span>Checklists</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <NavLink class="bottom-nav-item" href="about">
            <i class="bi bi-info-circle"></i>
            <span>About</span>
        </NavLink>
    </nav>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    [Inject] private IUserIdentity UserIdentity { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool menuOpen;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            UserIdentity.SetAuthenticatedUser(user);
        }
    }

    private void ToggleMenu() => menuOpen = !menuOpen;
}
